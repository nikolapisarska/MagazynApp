<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MagazynApp.DashboardPage"
             BackgroundColor="#121212">

    <VerticalStackLayout Padding="20" Spacing="20">
        
        <Grid ColumnDefinitions="Auto, *, Auto">
            <Label Grid.Column="2" Text="Status: Online" VerticalOptions="Center" TextColor="LightGreen" />
        </Grid>

        <Grid Grid.Row="0" HeightRequest="60" >
            <Label Text="Panel Magazynowy" TextColor="White" FontSize="30" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center"/>
        </Grid>

        
        <VerticalStackLayout Spacing="15" Margin="0,50,0,20">
            <Button Text="ROZPOCZNIJ KOMPLETACJĘ" 
                    Clicked="OnStartPickingClicked" 
                    BackgroundColor="#fcc821" 
                    TextColor="Black" 
                    FontAttributes="Bold" 
                    HeightRequest="60"/><Label Text="Wybierz nowe zamówienie" HorizontalOptions="Center" TextColor="Gray" FontSize="12"/>

            <Button Text="WERYFIKUJ KARTON" 
                    Clicked="OnVerifyCartonClicked"
                    BackgroundColor="#2D2D2D" TextColor="White" 
                    BorderColor="#fcc821" BorderWidth="1" HeightRequest="60" Margin="0,50,0,0"/>
            <Label Text="Skanuj kod, zobacz co jest w środku" HorizontalOptions="Center" TextColor="Gray" FontSize="12"/>
        </VerticalStackLayout>
        
    <VerticalStackLayout Spacing="10" Margin="0,20,0,0">
        <Button Text="EXPORT DANYCH" 
                Command="{Binding ExportDataCommand}"
                BackgroundColor="Gray" />
                    
        <Button Text="IMPORT DANYCH" 
                Command="{Binding ImportDataCommand}"
                BackgroundColor="Gray" />
    </VerticalStackLayout>
        
    </VerticalStackLayout>
</ContentPage>