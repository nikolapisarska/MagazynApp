<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             x:Class="MagazynApp.BoxSearchPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
        
        <!-- Nagłówek -->
        <Grid Grid.Row="0" HeightRequest="60" BackgroundColor="#1E1E1E">
            <Label Text="Centrum Operacyjne" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center"/>
        </Grid>

        <!-- Wyszukiwarka i status (zawsze widoczne) -->
        <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="8">
            <SearchBar x:Name="ScanEntry"
                       Text="{Binding ScanInput}"
                       SearchCommand="{Binding ProcessScanCommand}"
                       Placeholder="Zeskanuj kod kartonu..."
                       PlaceholderColor="Gray"
                       TextColor="White" 
                       BackgroundColor="#424242" />
            <Label Text="{Binding StatusMessage}" TextColor="Yellow" FontSize="12" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Informacje o kartonie -->
        <VerticalStackLayout Grid.Row="2" Padding="15" Spacing="8" BackgroundColor="#2C2C2C"
                             IsVisible="{Binding HasBoxLoaded}">
            <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" FontSize="22" FontAttributes="Bold" TextColor="White"/>
            <Label Text="{Binding CurrentBox.Status, StringFormat='Status: {0}'}" TextColor="#FFB300" FontAttributes="Bold"/>
    
            <!--Pole wagi -->
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="Waga:" TextColor="Gray" VerticalOptions="Center" FontSize="14"/>
                <Label Text="{Binding CurrentBox.Weight, StringFormat='{0} kg'}" 
                       TextColor="White" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                <Label Text="Wymiary:" TextColor="Gray" VerticalOptions="Center" FontSize="14"/>
                
                <Label Text="{Binding CurrentBox.Length, StringFormat='{0}'}" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Text="x" TextColor="Gray" FontSize="14" VerticalOptions="Center"/>
                
                <Label Text="{Binding CurrentBox.Width, StringFormat='{0}'}" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Text="x" TextColor="Gray" FontSize="14" VerticalOptions="Center"/>
                
                <Label Text="{Binding CurrentBox.Height, StringFormat='{0} cm'}" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Lista produktów w kartonie (widoczna tylko po załadowaniu) -->
        <CollectionView Grid.Row="3" ItemsSource="{Binding CurrentBox.Items}"
                        IsVisible="{Binding HasBoxLoaded}">
            <CollectionView.Header>
                <Grid Padding="10" ColumnDefinitions="*, 80" BackgroundColor="#1E1E1E" Margin="0,0,0,5">
                    <Label Text="Produkt" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Stan" Grid.Column="1" HorizontalOptions="Center" FontAttributes="Bold" TextColor="White"/>
                </Grid>
            </CollectionView.Header>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="15" ColumnDefinitions="*, 100" BackgroundColor="#242424" Margin="0,2">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=OpenIssuePopupCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="{Binding ProductName}" TextColor="White" FontAttributes="Bold"/>
                            <Label Text="{Binding StatusLabel}" 
                                   TextColor="{Binding StatusColor}" 
                                   FontSize="11" 
                                   FontAttributes="Italic"/>
                        </VerticalStackLayout>

                        <Label Grid.Column="1" 
                               HorizontalOptions="End" 
                               VerticalOptions="Center" 
                               FontSize="16"
                               FontAttributes="Bold"
                               Text="{Binding ExpectedVsConfirmed}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsFlagged}" Value="True">
                                    <Setter Property="TextColor" Value="Orange" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsFlagged}" Value="False">
                                    <Setter Property="TextColor" Value="White" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Dolny panel z przyciskami (widoczny tylko po załadowaniu) -->
      
        <!-- Dolny panel z przyciskami -->
        <VerticalStackLayout Grid.Row="4" Spacing="10" Padding="15" BackgroundColor="#1E1E1E"
                             IsVisible="{Binding HasBoxLoaded}">

            <Button Text="Dodaj Produkt" 
                    Command="{Binding AddProductCommand}" 
                    IsVisible="{Binding IsEditable}"
                    BackgroundColor="#4CAF50" 
                    TextColor="White" 
                    FontAttributes="Bold"/>
            
            <Button Text="Weryfikuj Zgodność" 
                    Command="{Binding StartVerificationCommand}" 
                    BackgroundColor="#fcc821" 
                    TextColor="Black" 
                    FontAttributes="Bold" 
                    HeightRequest="50"/>

            <!-- NOWY PRZYCISK: Widoczny tylko wtedy, gdy karton jest zamknięty -->
            <Button Text="Otwórz Karton Ponownie" 
                    Command="{Binding ReopenBoxCommand}"
                    IsVisible="{Binding CurrentBox.IsClosed}"
                    BackgroundColor="#FF9800" 
                    TextColor="Black" 
                    FontAttributes="Bold" 
                    HeightRequest="45"/>

            <Button Text="Zamknij Karton" 
                    Command="{Binding CloseBoxCommand}" 
                    IsEnabled="{Binding CanCloseBox}"
                    BackgroundColor="#2196F3" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    HeightRequest="45">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding CanCloseBox}" Value="False">
                        <Setter Property="BackgroundColor" Value="#555555" />
                        <Setter Property="TextColor" Value="#AAAAAA" />
                    </DataTrigger>
                </Button.Triggers>
            </Button> 
        </VerticalStackLayout>
    </Grid>
</ContentPage>