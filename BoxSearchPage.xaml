<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             x:Class="MagazynApp.BoxSearchPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">
    <VerticalStackLayout Padding="10">
        <!-- Nagłówek -->
        <Label Text="{Binding CurrentBox.BoxCode}" FontSize="24" FontAttributes="Bold"/>
        <Label Text="{Binding CurrentBox.Status}" />
        
        <!-- Lista produktów -->
        <CollectionView ItemsSource="{Binding CurrentBox.Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto, Auto" BackgroundColor="{Binding StatusColor}">
                        <Label Text="{Binding ProductName}" Grid.Column="0"/>
                        <Label Text="{Binding ExpectedVsConfirmed}" Grid.Column="1"/>
                        <Button Text="Edytuj️" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=EditQuantityCommand}" CommandParameter="{Binding .}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <CollectionView ItemsSource="{Binding CurrentBox.Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="*, 80, 80, Auto">
                        <Grid.Background>
                            <!-- Zmiana koloru w zależności od weryfikacji -->
                            <SolidColorBrush Color="{Binding StatusColor}" />
                        </Grid.Background>
                
                        <Label Text="{Binding ProductName}" Grid.Column="0" VerticalOptions="Center"/>
                        <Label Text="{Binding ExpectedQuantity}" Grid.Column="1" HorizontalOptions="Center"/>
                        <Label Text="{Binding ConfirmedQuantity}" Grid.Column="2" FontAttributes="Bold" HorizontalOptions="Center"/>
                
                        <ImageButton Source="edit_icon.png" 
                                     Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=EditQuantityCommand}" 
                                     CommandParameter="{Binding .}"
                                     IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=CurrentBox.IsEditable}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <!-- Action Bar -->
        <HorizontalStackLayout>
            <Button Text="Rozpocznij Inwentaryzację" Command="{Binding StartVerificationCommand}" />
            <Button Text="Zgłoś rozbieżność" Command="{Binding ReportIssueCommand}" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>