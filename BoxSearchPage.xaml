<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             x:Class="MagazynApp.BoxSearchPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <!-- Główny kontener Grid dla całej strony -->
    <Grid RowDefinitions="Auto, Auto, *">

        <!-- ============================== -->
        <!-- 1. GÓRNY PASEK (Stała wysokość) -->
        <!-- ============================== -->
        <Grid Grid.Row="0" 
              HeightRequest="60" 
              BackgroundColor="#1E1E1E" 
              ColumnDefinitions="60, *, 60">

            <!-- Przycisk powrotu -->
            <Button Grid.Column="0" 
                    Text="&#x2190;" 
                    FontSize="24" 
                    TextColor="White" 
                    BackgroundColor="Transparent"
                    Command="{Binding GoBackToMainCommand}"
                    VerticalOptions="Center" 
                    HorizontalOptions="Center"
                    Padding="0"/>

            <!-- Tytuł -->
            <Label Grid.Column="1" 
                   Text="Centrum Operacyjne" 
                   TextColor="White" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" 
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- ============================================== -->
        <!-- 2. SEKCJA WYSZUKIWANIA (Zawsze widoczna) -->
        <!-- ============================================== -->
        <VerticalStackLayout Grid.Row="1" 
                             Padding="15, 10" 
                             Spacing="8" 
                             BackgroundColor="#181818">
            
            <SearchBar x:Name="ScanEntry"
                       Text="{Binding ScanInput}"
                       SearchCommand="{Binding ProcessScanCommand}"
                       Placeholder="Zeskanuj kod kartonu..."
                       PlaceholderColor="#757575" 
                       TextColor="White" 
                       BackgroundColor="#303030"
                       HeightRequest="45"/>
            
            <Label Text="{Binding StatusMessage}" 
                   TextColor="#FFC107" 
                   FontSize="12" 
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- =================================================================== -->
        <!-- 3. GŁÓWNA ZAWARTOŚĆ (Dopasowana do telefonu lub laptopa) -->
        <!-- =================================================================== -->
        <ContentView Grid.Row="2" Padding="0, 10, 0, 0">
            <OnIdiom x:TypeArguments="View">
                
                <!-- +++++++++++++++++++++++++++++++++++++++++++++++++++++ -->
                <!-- WERSJA DLA TELEFONU / SKANERA (Układ pionowy) -->
                <!-- +++++++++++++++++++++++++++++++++++++++++++++++++++++ -->
                <OnIdiom.Phone>
                    <Grid RowDefinitions="Auto, *, Auto">
                        
                        <!-- Informacje o kartonie -->
                        <VerticalStackLayout Grid.Row="0" 
                                             Padding="15, 10" 
                                             Spacing="6" 
                                             BackgroundColor="#212121"
                                             IsVisible="{Binding HasBoxLoaded}">
                            
                            <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" 
                                   FontSize="22" 
                                   FontAttributes="Bold" 
                                   TextColor="White"/>
                            
                            <Label Text="{Binding CurrentBox.Status, StringFormat='Status: {0}'}" 
                                   TextColor="#FFC107" 
                                   FontAttributes="Bold"
                                   FontSize="14"/>
            
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Label Text="Waga:" TextColor="#BDBDBD" VerticalOptions="Center" FontSize="13"/>
                                <Label Text="{Binding CurrentBox.Weight, StringFormat='{0} kg'}" 
                                       TextColor="White" 
                                       FontSize="13" 
                                       FontAttributes="Bold"/>
                                
                                <BoxView WidthRequest="1" Color="#424242" Margin="5,0"/>

                                <Label Text="Wymiary:" TextColor="#BDBDBD" VerticalOptions="Center" FontSize="13"/>
                                <Label Text="{Binding CurrentBox.Length}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="x" TextColor="#BDBDBD" FontSize="13"/>
                                <Label Text="{Binding CurrentBox.Width}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="x" TextColor="#BDBDBD" FontSize="13"/>
                                <Label Text="{Binding CurrentBox.Height, StringFormat='{0} cm'}" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Lista produktów -->
                        <CollectionView Grid.Row="1" 
                                        ItemsSource="{Binding CurrentBox.Items}"
                                        IsVisible="{Binding HasBoxLoaded}"
                                        Margin="0, 5, 0, 0"
                                        BackgroundColor="#121212">
                            
                            <CollectionView.Header>
                                <Grid Padding="15, 5" ColumnDefinitions="*, 90" BackgroundColor="#212121">
                                    <Label Text="Produkt" FontAttributes="Bold" TextColor="#EEEEEE" FontSize="13"/>
                                    <Label Text="Stan" Grid.Column="1" HorizontalOptions="End" FontAttributes="Bold" TextColor="#EEEEEE" FontSize="13"/>
                                </Grid>
                            </CollectionView.Header>
                            
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="15, 12" 
                                          ColumnDefinitions="*, 100" 
                                          BackgroundColor="#1E1E1E" 
                                          Margin="0, 1">
                                        
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=OpenIssuePopupCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                            <Label Text="{Binding ProductName}" TextColor="White" FontAttributes="Bold" FontSize="15"/>
                                            <Label Text="{Binding ProductId}" TextColor="#9E9E9E" FontSize="12"/>
                                            <Label Text="{Binding StatusLabel}" 
                                                   TextColor="{Binding StatusColor}" 
                                                   FontSize="11" 
                                                   FontAttributes="Italic"/>
                                        </VerticalStackLayout>

                                        <Label Grid.Column="1" 
                                               HorizontalOptions="End" 
                                               VerticalOptions="Center" 
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               Text="{Binding ExpectedVsConfirmed}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsFlagged}" Value="True">
                                                    <Setter Property="TextColor" Value="#FF9800" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsFlagged}" Value="False">
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Dolny panel przycisków -->
                        <VerticalStackLayout Grid.Row="2" 
                                             Spacing="8" 
                                             Padding="12" 
                                             BackgroundColor="#181818"
                                             IsVisible="{Binding HasBoxLoaded}">

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                <Button Grid.Column="0" 
                                        Text="Dodaj" 
                                        Command="{Binding AddProductCommand}" 
                                        IsVisible="{Binding IsEditable}"
                                        BackgroundColor="#388E3C" 
                                        TextColor="White" 
                                        FontAttributes="Bold"             
                                        HeightRequest="50"
                                        CornerRadius="5"/>
            
                                <Button Grid.Column="1" 
                                        Text="Weryfikuj" 
                                        Command="{Binding StartVerificationCommand}" 
                                        BackgroundColor="#FBC02D" 
                                        TextColor="Black" 
                                        FontAttributes="Bold" 
                                        HeightRequest="50"
                                        CornerRadius="5"/>
                            </Grid>

                            <Button Text="Otwórz Ponownie" 
                                    Command="{Binding ReopenBoxCommand}"
                                    IsVisible="{Binding CurrentBox.IsClosed}"
                                    BackgroundColor="#F57C00" 
                                    TextColor="Black" 
                                    FontAttributes="Bold" 
                                    HeightRequest="50"
                                    CornerRadius="5"/>

                            <Button Text="Zamknij Karton" 
                                    Command="{Binding CloseBoxCommand}" 
                                    IsEnabled="{Binding CanCloseBox}"
                                    BackgroundColor="#1976D2" 
                                    TextColor="White" 
                                    FontAttributes="Bold" 
                                    HeightRequest="50"
                                    CornerRadius="5">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding CanCloseBox}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#424242" />
                                        <Setter Property="TextColor" Value="#9E9E9E" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button> 
                        </VerticalStackLayout>
                    </Grid>
                </OnIdiom.Phone>

                <!-- +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++ -->
                <!-- WERSJA DLA DESKTOP / LAPTOPA (Układ dwukolumnowy) -->
                <!-- +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++ -->
                <OnIdiom.Desktop>
                    <Grid ColumnDefinitions="320, *" IsVisible="{Binding HasBoxLoaded}" BackgroundColor="#121212">
                        
                        <!-- LEWA KOLUMNA: Informacje o kartonie i przyciski -->
                        <Grid Grid.Column="0" RowDefinitions="Auto, *" BackgroundColor="#181818" Padding="15">
                            
                            <VerticalStackLayout Grid.Row="0" Spacing="10">
                                <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" FontSize="24" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="{Binding CurrentBox.Status, StringFormat='Status: {0}'}" TextColor="#FFC107" FontAttributes="Bold" FontSize="16"/>
                                
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Waga:" TextColor="#BDBDBD" FontSize="14"/>
                                    <Label Text="{Binding CurrentBox.Weight, StringFormat='{0} kg'}" TextColor="White" FontAttributes="Bold" FontSize="14"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Wymiary:" TextColor="#BDBDBD" FontSize="14"/>
                                    <Label Text="{Binding CurrentBox.Length}" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                    <Label Text="x" TextColor="#BDBDBD"/>
                                    <Label Text="{Binding CurrentBox.Width}" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                    <Label Text="x" TextColor="#BDBDBD"/>
                                    <Label Text="{Binding CurrentBox.Height, StringFormat='{0} cm'}" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                                
                                <BoxView HeightRequest="1" Color="#424242" Margin="0,10"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Spacing="12" VerticalOptions="Start">
                                <Label Text="Akcje" TextColor="#757575" FontSize="12" FontAttributes="Bold"/>
                                
                                <Button Text="Dodaj Produkt" Command="{Binding AddProductCommand}" IsVisible="{Binding IsEditable}" BackgroundColor="#388E3C" TextColor="White" HeightRequest="50" FontAttributes="Bold" CornerRadius="5"/>
                                <Button Text="Weryfikuj Zgodność" Command="{Binding StartVerificationCommand}" BackgroundColor="#FBC02D" TextColor="Black" HeightRequest="50" FontAttributes="Bold" CornerRadius="5"/>
                                <Button Text="Otwórz Ponownie" Command="{Binding ReopenBoxCommand}" IsVisible="{Binding CurrentBox.IsClosed}" BackgroundColor="#F57C00" TextColor="Black" HeightRequest="50" FontAttributes="Bold" CornerRadius="5"/>
                                <Button Text="Zamknij Karton" Command="{Binding CloseBoxCommand}" IsEnabled="{Binding CanCloseBox}" BackgroundColor="#1976D2" TextColor="White" HeightRequest="50" FontAttributes="Bold" CornerRadius="5">
                                     <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding CanCloseBox}" Value="False">
                                            <Setter Property="BackgroundColor" Value="#424242" />
                                            <Setter Property="TextColor" Value="#9E9E9E" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- PRAWA KOLUMNA: Lista produktów -->
                        <CollectionView Grid.Column="1" 
                                        ItemsSource="{Binding CurrentBox.Items}"
                                        Margin="10,0,0,0"
                                        BackgroundColor="#121212">
                            <CollectionView.Header>
                                <Grid Padding="20, 8" ColumnDefinitions="*, 150" BackgroundColor="#212121">
                                    <Label Text="Produkt" FontAttributes="Bold" TextColor="#EEEEEE"/>
                                    <Label Text="Stan (Fakt / Oczek)" Grid.Column="1" HorizontalOptions="End" FontAttributes="Bold" TextColor="#EEEEEE"/>
                                </Grid>
                            </CollectionView.Header>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="20, 15" ColumnDefinitions="*, 200" BackgroundColor="#1E1E1E" Margin="0, 2">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SearchViewModel}}, Path=OpenIssuePopupCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <VerticalStackLayout VerticalOptions="Center">
                                            <Label Text="{Binding ProductName}" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                            <Label Text="{Binding ProductId}" TextColor="#9E9E9E" FontSize="13"/>
                                            <Label Text="{Binding StatusLabel}" TextColor="{Binding StatusColor}" FontSize="12" FontAttributes="Italic"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" 
                                               HorizontalOptions="End" 
                                               VerticalOptions="Center" 
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               Text="{Binding ExpectedVsConfirmed}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsFlagged}" Value="True">
                                                    <Setter Property="TextColor" Value="#FF9800" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsFlagged}" Value="False">
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </OnIdiom.Desktop>
            </OnIdiom>
        </ContentView>
    </Grid>
</ContentPage>