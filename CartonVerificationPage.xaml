<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             x:Class="MagazynApp.CartonVerificationPage"
             BackgroundColor="#121212">

    <Grid Padding="20" RowDefinitions="Auto, Auto, *, Auto" RowSpacing="15">
        <VerticalStackLayout Grid.Row="0">
            <Label Text="Weryfikacja Kartonu" TextColor="White" FontSize="24" FontAttributes="Bold"/>
            <ProgressBar Progress="{Binding ProgressValue}" ProgressColor="#4CAF50" HeightRequest="8" Margin="0,10,0,0"/>
        </VerticalStackLayout>
        
        <Entry x:Name="ScanSearchBar" Grid.Row="1" Text="{Binding ScanInput}" Placeholder="Skanuj kod..." 
               ReturnCommand="{Binding ProcessScanCommand}" BackgroundColor="#1E1E1E" HeightRequest="50" TextColor="White"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding CurrentItems}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#1E1E1E" Margin="0,5" Padding="15">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding ProductName}" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="{Binding StatusLabel}" TextColor="{Binding StatusColor}" FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding ExpectedVsConfirmed}" FontSize="18" VerticalOptions="Center" Margin="0,0,15,0"/>
                            <HorizontalStackLayout Grid.Column="2" Spacing="5">
                                <Button Text="Brak" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ReportMissingCommand}" CommandParameter="{Binding .}" BackgroundColor="#FBC02D"/>
                                <Button Text="Uszk" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveDamagedCommand}" CommandParameter="{Binding .}" BackgroundColor="#D32F2F"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="3" Text="ZAMKNIJ KARTON" Command="{Binding SaveAndCloseCommand}" BackgroundColor="#2196F3" HeightRequest="50"/>
    </Grid>
</ContentPage>