<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             x:Class="MagazynApp.MainPage"
             Title="Panel Magazynowy"
             BackgroundColor="#121212"> 

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="White" />
        </Style>
        <Style TargetType="Entry">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="BackgroundColor" Value="#1E1E1E" />
            <Setter Property="PlaceholderColor" Value="#757575" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" MaximumWidthRequest="550" HorizontalOptions="Center">
            
            <Border StrokeThickness="1" Stroke="#333333" Padding="15" StrokeShape="RoundRectangle 10" BackgroundColor="#1E1E1E">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Pole Skanera (Zeskanuj Karton lub Produkt):" FontAttributes="Bold" FontSize="14" />
                    <Entry x:Name="ScanEntry"
                           Text="{Binding ScanInput}"
                           ReturnCommand="{Binding ProcessScanCommand}"
                           Completed="OnScanEntryCompleted"
                           Placeholder="Wpisz/Zeskanuj kod ..."
                           FontSize="18" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding StatusMessage}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontAttributes="Italic"
                   FontSize="15"
                   TextColor="#2196F3" /> <VerticalStackLayout Spacing="15" IsVisible="{Binding IsBoxOpen}">
                
                <Label Text="{Binding CurrentBox.BoxCode, StringFormat=' Kod kartonu: {0}'}" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="#FFFFFF"/>

                <Line Stroke="#333333" X2="500" HorizontalOptions="Fill" StrokeThickness="1"/>

                <Label Text="Wymiary i waga opakowania:" FontAttributes="Bold" FontSize="14"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="15" RowSpacing="15">
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                        <Label Text="Waga (kg):" FontSize="12" TextColor="#BDBDBD"/>
                        <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Weight, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                        <Label Text="Długość (cm):" FontSize="12" TextColor="#BDBDBD"/>
                        <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Length, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                        <Label Text="Szerokość (cm):" FontSize="12" TextColor="#BDBDBD"/>
                        <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Width, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                        <Label Text="Wysokość (cm):" FontSize="12" TextColor="#BDBDBD"/>
                        <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Height, Mode=TwoWay}" />
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Zawartość kartonu:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0"/>
                
                <Border StrokeThickness="1" Stroke="#333333" Padding="5" StrokeShape="RoundRectangle 5" BackgroundColor="#1E1E1E">
                    <CollectionView ItemsSource="{Binding CurrentItems}" EmptyView="Pusty karton. Zeskanuj produkty.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto" Padding="10">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="15"/>
                                        <Label Text="{Binding ProductSku, StringFormat='Indeks: {0}'}" FontSize="12" TextColor="#BDBDBD"/>
                                    </VerticalStackLayout>
                                    
                                    <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                        <Label Text="Sztuk:" VerticalOptions="Center" FontSize="13"/>
                                        <Entry Text="{Binding Quantity, Mode=TwoWay}" 
                                               Keyboard="Numeric" 
                                               WidthRequest="60" 
                                               HorizontalTextAlignment="Center"
                                               BackgroundColor="#2C2C2C"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <Button Text="Zatwierdź i Zapisz Karton w Bazie"
                        Clicked="OnSaveAndCloseClicked"
                        BackgroundColor="#00C853"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="55"
                        Margin="0,15,0,0"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>