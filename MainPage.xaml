<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MagazynApp.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, Auto, *" RowSpacing="10">
        
        <!-- NIEBIESKI NAGŁÓWEK -->
        <Grid Grid.Row="0" HeightRequest="60" BackgroundColor="#1E3F5C">
            <Label Text="Panel Magazynowy"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>

        <!-- SEKCJA 1: Skaner -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 8" Margin="15,5,15,0" Padding="10">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Status: Aktywny" TextColor="#2E7D32" FontAttributes="Bold" FontSize="14"/>
                    <Label Grid.Column="1" Text="Operator: User" TextColor="#757575" FontSize="12"/>
                </Grid>

                <Label Text="Zeskanuj kod produktu (Graffiti):" FontAttributes="Bold" FontSize="13" TextColor="#424242"/>
                
                <Grid HeightRequest="100" BackgroundColor="#EEEEEE">
                    <BoxView Color="#E0E0E0" WidthRequest="150" HeightRequest="60" HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Label Text="[Wizjer Skanera]" VerticalOptions="Center" HorizontalOptions="Center" TextColor="#9E9E9E"/>
                </Grid>

                <Entry x:Name="ScanEntry"
                       Text="{Binding ScanInput}"
                       ReturnCommand="{Binding ProcessScanCommand}"
                       Completed="OnScanEntryCompleted"
                       Placeholder="Kliknij lub zeskanuj..."
                       ClearButtonVisibility="WhileEditing"/>
                <Label Text="{Binding StatusMessage}" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"
                       TextColor="#D32F2F" 
                       Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <!-- SEKCJA 2: Szczegóły -->
        <ScrollView Grid.Row="2" Padding="15,0,15,15">
            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsBoxOpen}">
                
                <!-- Kod kartonu -->
                <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#212121"
                       HorizontalOptions="Center"/>

                <!-- Wymiary i Waga -->
                <Border StrokeShape="RoundRectangle 8" Padding="10">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Wymiary i waga (opcjonalne):" FontAttributes="Bold" FontSize="14" TextColor="#424242"/>
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Spacing="2">
                                <Label Text="Waga (kg)" FontSize="12" TextColor="#757575"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Weight, Mode=TwoWay}" Placeholder="0.00"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                                <Label Text="Dł. (cm)" FontSize="12" TextColor="#757575"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Length, Mode=TwoWay}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                <Label Text="Szer. (cm)" FontSize="12" TextColor="#757575"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Width, Mode=TwoWay}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="2" Spacing="2">
                                <Label Text="Wys. (cm)" FontSize="12" TextColor="#757575"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Height, Mode=TwoWay}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Zawartość -->
                <Label Text="Zawartość:" FontAttributes="Bold" FontSize="14" Margin="0,5,0,-5" TextColor="#424242"/>
                <Border StrokeShape="RoundRectangle 8" Padding="0">
                    <CollectionView ItemsSource="{Binding CurrentItems}" EmptyView="Pusty karton. Zeskanuj produkty." HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto" Padding="15,10" MinimumHeightRequest="60">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="16" TextColor="#212121"/>
                                        <Label Text="{Binding ProductSku, StringFormat='Indeks: {0}'}" FontSize="12" TextColor="#757575"/>
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                        <Button Text="-" Command="{Binding DecrementQuantityCommand}" WidthRequest="45" HeightRequest="45" CornerRadius="22" BackgroundColor="#E0E0E0" TextColor="Black" FontSize="20"/>
                                        <Label Text="{Binding Quantity, Mode=TwoWay}" FontSize="22" FontAttributes="Bold" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" WidthRequest="40" TextColor="#212121"/>
                                        <Button Text="+" Command="{Binding IncrementQuantityCommand}" WidthRequest="45" HeightRequest="45" CornerRadius="22" BackgroundColor="#E0E0E0" TextColor="Black" FontSize="20"/>
                                    </HorizontalStackLayout>
                                    <BoxView Grid.ColumnSpan="2" HeightRequest="1" Color="#EEEEEE" VerticalOptions="End" Margin="15,0"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <!-- Przycisk finalizacji -->
                <Button Text="ZAMKNIJ I ZAPISZ KARTON"
                        Clicked="OnSaveAndCloseClicked"
                        BackgroundColor="#DB5F26" 
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="60"
                        Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>