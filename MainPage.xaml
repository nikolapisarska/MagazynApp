<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             xmlns:model="clr-namespace:MagazynApp.Model"
             x:Class="MagazynApp.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid RowDefinitions="60, *" RowSpacing="0">
        <!-- Górny pasek stały -->
        <Grid Grid.Row="0" BackgroundColor="#1E1E1E" ColumnDefinitions="60, *, 60">
            <Button Grid.Column="0" 
                    Text="&#x2190;" 
                    FontSize="24" 
                    TextColor="White" 
                    BackgroundColor="Transparent"
                    Command="{Binding GoBackCommand}"
                    VerticalOptions="Center" 
                    HorizontalOptions="Center"
                    Padding="0"/>

            <Label Grid.Column="1" 
                   Text="Panel Magazynowy"
                   TextColor="White" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" 
                   HorizontalOptions="Center"/>
       </Grid>

        <!-- SCROLLVIEW DLA CAŁOŚCI -->
        <ScrollView Grid.Row="1" Padding="12">
            <FlexLayout Direction="Row" 
                        Wrap="Wrap" 
                        JustifyContent="Center" 
                        AlignItems="Start">

                <!-- LEWA SEKCJA: PANEL SKANOWANIA -->
                <Border StrokeShape="RoundRectangle 8" 
                        Padding="14" 
                        BackgroundColor="#1E1E1E" 
                        Stroke="#2A2A2A"
                        StrokeThickness="1"
                        Margin="6"
                        FlexLayout.Basis="{OnIdiom Desktop='380', Phone='100%'}"
                        FlexLayout.Grow="1">
                    <VerticalStackLayout Spacing="12">
                        
                        <!-- Status w formie nowoczesnej kapsułki -->
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Label Text="Status:" FontSize="13" TextColor="#9E9E9E" VerticalOptions="Center"/>
                            <Border Padding="8, 3" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsEditable}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#332700" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsEditable}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#3B1D1D" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding CurrentBox.Status}" FontAttributes="Bold" FontSize="13">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsEditable}" Value="True">
                                            <Setter Property="TextColor" Value="#FFC107" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsEditable}" Value="False">
                                            <Setter Property="TextColor" Value="#EF5350" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </HorizontalStackLayout>
                        
                        <Label Text="Zeskanuj kod produktu (Graffiti):" FontAttributes="Bold" FontSize="13" TextColor="#BDBDBD"/>
                        
                        <SearchBar x:Name="ScanEntry"
                                   Text="{Binding ScanInput}"
                                   SearchCommand="{Binding ProcessScanCommand}"
                                   Placeholder="Zeskanuj kod..."
                                   PlaceholderColor="#757575"
                                   TextColor="White" 
                                   BackgroundColor="#2A2A2A"
                                   HeightRequest="45"/>

                        <Label Text="{Binding StatusMessage}" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#81C784" Margin="0,2"/>

                        <Border IsVisible="{Binding IsProductVisible}" 
                                Padding="12" 
                                BackgroundColor="#252525" 
                                Stroke="#333333"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Znaleziony produkt:" FontSize="11" TextColor="#9E9E9E"/>
                                <Label Text="{Binding FoundProduct.Name}" FontAttributes="Bold" TextColor="White" FontSize="14"/>
                                <Label Text="{Binding FoundProduct.CodeOrIdGraffiti, StringFormat='Kod: {0}'}" TextColor="#FFC107" FontSize="13"/>
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding FoundClosedBoxes}" Spacing="6">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="model:Box">
                                    <Border Margin="0,2" 
                                            Padding="12" 
                                            BackgroundColor="#252525" 
                                            Stroke="#333333"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 6">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=OpenBoxCommand}"
                                                                  CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                            <Label Text="Karton:" FontAttributes="Bold" TextColor="#9E9E9E" VerticalOptions="Center"/>
                                            <Label Text="{Binding BoxCode}" TextColor="#FFC107" FontAttributes="Bold" FontSize="15" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- PRAWA SEKCJA: ZAWARTOŚĆ KARTONU -->
                <VerticalStackLayout Spacing="14" 
                                     IsVisible="{Binding IsBoxOpen}"
                                     Margin="6"
                                     FlexLayout.Basis="{OnIdiom Desktop='650', Phone='100%'}"
                                     FlexLayout.Grow="2">
                    
                    <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,4,0,0"/>

                    <Border StrokeShape="RoundRectangle 8" 
                            Padding="14" 
                            BackgroundColor="#1E1E1E" 
                            Stroke="#2A2A2A"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Wymiary i waga (opcjonalne):" FontAttributes="Bold" FontSize="13" TextColor="#FFC107"/>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Spacing="3">
                                    <Label Text="Waga (kg)" FontSize="12" TextColor="#BDBDBD"/>
                                    <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Weight, Mode=TwoWay}" Placeholder="0.00" PlaceholderColor="#666" TextColor="White" BackgroundColor="#2A2A2A" HeightRequest="40"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="3">
                                    <Label Text="Dł. (cm)" FontSize="12" TextColor="#BDBDBD"/>
                                    <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Length, Mode=TwoWay}" TextColor="White" BackgroundColor="#2A2A2A" HeightRequest="40"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="3">
                                    <Label Text="Szer. (cm)" FontSize="12" TextColor="#BDBDBD"/>
                                    <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Width, Mode=TwoWay}" TextColor="White" BackgroundColor="#2A2A2A" HeightRequest="40"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="2" Spacing="3">
                                    <Label Text="Wys. (cm)" FontSize="12" TextColor="#BDBDBD"/>
                                    <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Height, Mode=TwoWay}" TextColor="White" BackgroundColor="#2A2A2A" HeightRequest="40"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="Zawartość:" FontAttributes="Bold" FontSize="13" Margin="0,4,0,-2" TextColor="#BDBDBD"/>

                    <!-- Tabela produktów z zaokrąglonymi krawędziami -->
                    <Border StrokeThickness="1" 
                            Stroke="#2A2A2A"
                            BackgroundColor="#1E1E1E" 
                            StrokeShape="RoundRectangle 8" 
                            Padding="0">
                        <VerticalStackLayout Spacing="0">
                            <!-- Nagłówek tabeli z delikatniejszym żółtym odcieniem i lepszym wyśśietlaniem -->
                            <Grid ColumnDefinitions="40,110,*,85" HeightRequest="42" BackgroundColor="#E0A800">
                                <Label Grid.Column="0" Text="LP" FontAttributes="Bold" TextColor="Black" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                <Label Grid.Column="1" Text="INDEX" FontAttributes="Bold" TextColor="Black" FontSize="12" Margin="10,0" VerticalTextAlignment="Center"/>
                                <Label Grid.Column="2" Text="NAZWA TOWARU" FontAttributes="Bold" TextColor="Black" FontSize="12" Margin="10,0" VerticalTextAlignment="Center"/>
                                <Label Grid.Column="3" Text="ILOŚĆ" FontAttributes="Bold" TextColor="Black" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                            </Grid>

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding CurrentItems}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="model:Item">
                                        <VerticalStackLayout>
                                            <Grid ColumnDefinitions="40,110,*,80" Padding="4,8" BackgroundColor="#1E1E1E" VerticalOptions="Center">
                                                <Grid.Triggers>
                                                    <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#252525"/>
                                                    </DataTrigger>
                                                </Grid.Triggers>

                                                <Label Grid.Column="0" Text="{Binding Lp}" TextColor="White" FontSize="13" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                                                <Label Grid.Column="1" Text="{Binding ProductSku}" Margin="10,0" VerticalTextAlignment="Center" FontSize="13" TextColor="White" LineBreakMode="TailTruncation"/>
                                                <Label Grid.Column="2" Text="{Binding ProductName}" Margin="10,0" VerticalTextAlignment="Center" FontSize="13" LineBreakMode="WordWrap" TextColor="White"/>

                                                <Grid Grid.Column="3" ColumnDefinitions="*, 30" VerticalOptions="Center" HorizontalOptions="Center">
                                                    <Entry Text="{Binding Quantity, Mode=TwoWay}" 
                                                           Keyboard="Numeric"
                                                           TextColor="White"
                                                           FontSize="13"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           BackgroundColor="#2A2A2A"
                                                           HeightRequest="38"
                                                           WidthRequest="45"
                                                           Margin="0,0,2,0"/> 
                                                    <Button Grid.Column="1" 
                                                            Text="✕" 
                                                            TextColor="#EF5350"
                                                            BackgroundColor="Transparent"
                                                            FontSize="13"
                                                            FontAttributes="Bold"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveItemCommand}"
                                                            CommandParameter="{Binding .}"
                                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=IsEditable}"
                                                            VerticalOptions="Center"
                                                            HorizontalOptions="Center"
                                                            Padding="0"
                                                            WidthRequest="30"
                                                            HeightRequest="30"/>
                                                </Grid>
                                            </Grid>
                                            <BoxView HeightRequest="1" Color="#252525"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Przyciski akcji -->
                    <Button Text="IMPORTUJ LISTĘ PRODUKTÓW" 
                            Command="{Binding ImportItemsToBoxCommand}"
                            IsVisible="{Binding IsEditable}"
                            BackgroundColor="#1976D2" 
                            TextColor="White" 
                            FontSize="14" 
                            FontAttributes="Bold"
                            CornerRadius="6" 
                            HeightRequest="48"/>
                            
                    <Button Text="ZAPISZ KARTON" 
                            Command="{Binding SaveAndReturnCommand}" 
                            IsVisible="{Binding IsEditable}"
                            BackgroundColor="#FFC107" 
                            TextColor="Black" 
                            FontAttributes="Bold" 
                            FontSize="15" 
                            CornerRadius="6" 
                            HeightRequest="52" 
                            Margin="0,4,0,24"/>
                </VerticalStackLayout>
           
            </FlexLayout>
        </ScrollView>
    </Grid>
</ContentPage>