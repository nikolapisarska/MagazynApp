<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             xmlns:model="clr-namespace:MagazynApp.Model"
             x:Class="MagazynApp.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, Auto, *">
        
        <!-- Header -->
        <Grid Grid.Row="0" HeightRequest="60" BackgroundColor="#1E1E1E">
            <Label Text="Panel Magazynowy" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center"/>
        </Grid>

        <!-- Skaner -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 8" Margin="15,10,15,0" Padding="15" BackgroundColor="#2D2D2D" StrokeThickness="0">
            <VerticalStackLayout Spacing="8">
                <Label Text="Status: Aktywny" TextColor="#81C784" FontAttributes="Bold"/>
                <Entry x:Name="ScanEntry"
                       Text="{Binding ScanInput}"
                       Placeholder="Zeskanuj kod..."
                       TextColor="White" 
                       BackgroundColor="#424242"
                       Completed="OnScanEntryCompleted" />
            </VerticalStackLayout>
        </Border>

        <!-- Lista -->
        <ScrollView Grid.Row="2" Padding="15">
            <VerticalStackLayout Spacing="15" WidthRequest="{OnIdiom Desktop=600, Phone=-1}" HorizontalOptions="Center">
                
                <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>

                <!-- Nagłówek Tabeli -->
                <Grid ColumnDefinitions="40,120,*,80" BackgroundColor="#fcc821" HeightRequest="40">
                    <Label Grid.Column="0" Text="LP" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Label Grid.Column="1" Text="INDEX" FontAttributes="Bold" VerticalOptions="Center" Margin="10,0"/>
                    <Label Grid.Column="2" Text="NAZWA" FontAttributes="Bold" VerticalOptions="Center" Margin="10,0"/>
                    <Label Grid.Column="3" Text="ILOŚĆ" FontAttributes="Bold" VerticalOptions="Center" HorizontalOptions="Center"/>
                </Grid>

                <CollectionView ItemsSource="{Binding CurrentItems}" HeightRequest="400" BackgroundColor="#2B2B2B">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Item">
                            <Grid ColumnDefinitions="40,120,*,80" HeightRequest="50" BackgroundColor="#2B2B2B">
                                <!-- Trigger zamiast Convertera - nie wywali apki -->
                                <Grid.Triggers>
                                    <DataTrigger TargetType="Grid" Binding="{Binding IsEven}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#363636"/>
                                    </DataTrigger>
                                </Grid.Triggers>
                                
                                <Label Grid.Column="0" Text="{Binding Lp}" VerticalOptions="Center" HorizontalOptions="Center" TextColor="White"/>
                                <Label Grid.Column="1" Text="{Binding ProductSku}" VerticalOptions="Center" Margin="10,0" TextColor="White"/>
                                <Label Grid.Column="2" Text="{Binding ProductName}" VerticalOptions="Center" Margin="10,0" TextColor="White"/>
                                <Entry Grid.Column="3" Text="{Binding Quantity}" Keyboard="Numeric" VerticalOptions="Center" HorizontalOptions="Center" BackgroundColor="Transparent" TextColor="White"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="ZAMKNIJ I ZAPISZ" Clicked="OnSaveAndCloseClicked" BackgroundColor="#fcc821" TextColor="Black" FontAttributes="Bold" HeightRequest="50" Margin="0,10,0,30"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>