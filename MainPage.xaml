<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MagazynApp.ViewModels"
             x:Class="MagazynApp.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, Auto, *" RowSpacing="10">
        
        <Grid Grid.Row="0" HeightRequest="60" BackgroundColor="#1E1E1E">
            <Label Text="Panel Magazynowy"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
        </Grid>

        <Border Grid.Row="1" StrokeShape="RoundRectangle 8" Margin="15,5,15,0" Padding="10" BackgroundColor="#2D2D2D" StrokeThickness="0">
            <VerticalStackLayout Spacing="8">
                <Label Text="Status: Aktywny" TextColor="#81C784" FontAttributes="Bold" FontSize="14"/>

                <Label Text="Zeskanuj kod produktu (Graffiti):" FontAttributes="Bold" FontSize="13" TextColor="#BDBDBD"/>
                <SearchBar x:Name="ScanSearchBar"
                           Text="{Binding ScanInput}"
                           SearchCommand="{Binding ProcessScanCommand}"
                           Placeholder="Zeskanuj kod..."
                           PlaceholderColor="Gray"
                           TextColor="White" 
                           BackgroundColor="#424242" />
                <Label Text="{Binding StatusMessage}" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"
                       TextColor="#81C784" 
                       Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="2" Padding="15,0,15,15" WidthRequest="{OnIdiom Desktop=600, Phone=-1}" HorizontalOptions="Center">
            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsBoxOpen}">
                
                <Label Text="{Binding CurrentBox.BoxCode, StringFormat='Karton: {0}'}" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <Border StrokeShape="RoundRectangle 8" Padding="10" BackgroundColor="#2D2D2D" StrokeThickness="0">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Wymiary i waga (opcjonalne):" FontAttributes="Bold" FontSize="14" TextColor="#FFC107"/>
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Spacing="2">
                                <Label Text="Waga (kg)" FontSize="12" TextColor="#BDBDBD"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Weight, Mode=TwoWay}" Placeholder="0.00" TextColor="White" BackgroundColor="#424242"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                                <Label Text="Dł. (cm)" FontSize="12" TextColor="#BDBDBD"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Length, Mode=TwoWay}" TextColor="White" BackgroundColor="#424242"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                <Label Text="Szer. (cm)" FontSize="12" TextColor="#BDBDBD"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Width, Mode=TwoWay}" TextColor="White" BackgroundColor="#424242"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="2" Spacing="2">
                                <Label Text="Wys. (cm)" FontSize="12" TextColor="#BDBDBD"/>
                                <Entry Keyboard="Numeric" Text="{Binding CurrentBox.Height, Mode=TwoWay}" TextColor="White" BackgroundColor="#424242"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Zawartość:" FontAttributes="Bold" FontSize="14" Margin="0,5,0,-5" TextColor="#BDBDBD"/>
                <Border StrokeShape="RoundRectangle 8" Padding="0" BackgroundColor="#2D2D2D" StrokeThickness="0">
                    <CollectionView ItemsSource="{Binding CurrentItems}" EmptyView="Pusty karton. Zeskanuj produkty." HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, Auto, Auto" Padding="15,10" MinimumHeightRequest="60">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="16" TextColor="White"/>
                                        <Label Text="{Binding ProductSku, StringFormat='Indeks: {0}'}" FontSize="12" TextColor="#BDBDBD"/>
                                    </VerticalStackLayout>

                                    <Entry Grid.Column="1" 
                                           Text="{Binding Quantity, Mode=TwoWay}" 
                                           Keyboard="Numeric" 
                                           WidthRequest="60" 
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"
                                           TextColor="White"
                                           BackgroundColor="#424242"/>

                                    <Button Grid.Column="2" 
                                            Text="X" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveItemCommand}"
                                            CommandParameter="{Binding .}"
                                            TextColor="#FF5252"
                                            FontAttributes="Bold"
                                            BackgroundColor="Transparent"
                                            BorderColor="Transparent"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <Button Text="ZAMKNIJ I ZAPISZ KARTON"
                        Clicked="OnSaveAndCloseClicked"
                        BackgroundColor="#FFC107" 
                        TextColor="Black"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="60"
                        Margin="0,10,0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>